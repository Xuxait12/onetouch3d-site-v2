# =====================================================
# SUPABASE CONFIGURATION
# =====================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# =====================================================
# MERCADO PAGO - SANDBOX (DEVELOPMENT/TEST)
# =====================================================
# Get these credentials from: https://www.mercadopago.com.br/developers/panel/app
# Use TEST credentials for development

# Public Key (frontend) - Starts with TEST-
VITE_MERCADO_PAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# =====================================================
# MERCADO PAGO - PRODUCTION
# =====================================================
# Only use these when deploying to production
# Public Key (frontend) - Starts with APP_USR-
VITE_MERCADO_PAGO_PUBLIC_KEY_PROD=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# =====================================================
# EDGE FUNCTIONS SECRETS (Configure in Supabase Dashboard)
# =====================================================
# These should be configured in Supabase Dashboard → Project Settings → Edge Functions → Secrets
# DO NOT put these in .env file (only in Supabase Dashboard)
#
# MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# MERCADO_PAGO_ACCESS_TOKEN_PROD=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret-from-mp-panel
#
# To set these secrets:
# 1. Go to Supabase Dashboard
# 2. Project Settings → Edge Functions → Secrets
# 3. Add each secret with the name and value

# =====================================================
# NOTES
# =====================================================
# - Never commit real credentials to git
# - Copy this file to .env and fill with real values
# - Frontend variables must start with VITE_ to be exposed
# - Backend secrets go in Supabase Dashboard, not in .env
# - Use TEST credentials for development
# - Switch to PROD credentials only when ready for production
